# GE³ - Environment Variable Template
# Copy this file to .env and fill in your API credentials
# Only needed if you use cloud-based LLMs instead of local Ollama models

# Proxy configuration (optional, for Gemini etc.)
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# Doubao (ByteDance)
doubao_url=
doubao_api_key=

# SiliconFlow
sf_url=
sf_api_key=

# Google Gemini
gemini_url=
gemini_api_key=

# OpenAI-compatible
gpt_url=
gpt_api_key=
